{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optic-ray.local/schemas/phase3_ideal_scanner_line_path.schema.json",
  "title": "Optic Ray Phase 3 Ideal Scanner Line Path Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_type", "project_id", "scenario_id", "base_config_hash", "scanner_element_id", "waveform", "sample_count", "line_duration_s", "frequency_hz", "mechanical_amplitude_rad", "mechanical_amplitude_deg", "summary", "samples", "assumptions", "warnings"],
  "properties": {
    "schema_version": { "const": 1 },
    "report_type": { "const": "phase3_ideal_scanner_line_path" },
    "project_id": { "$ref": "common.schema.json#/$defs/identifier" },
    "scenario_id": { "$ref": "common.schema.json#/$defs/identifier" },
    "base_config_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "scanner_element_id": { "$ref": "common.schema.json#/$defs/identifier" },
    "waveform": { "enum": ["static", "triangle", "sinusoidal"] },
    "sample_count": { "type": "integer", "minimum": 1 },
    "line_duration_s": { "type": "number", "minimum": 0.0 },
    "frequency_hz": { "type": "number", "exclusiveMinimum": 0.0 },
    "mechanical_amplitude_rad": { "type": "number", "minimum": 0.0 },
    "mechanical_amplitude_deg": { "type": "number", "minimum": 0.0 },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_hit_count", "positive_return_count", "max_estimated_received_power_w", "min_estimated_received_power_w", "model_scope"],
      "properties": {
        "target_hit_count": { "type": "integer", "minimum": 0 },
        "positive_return_count": { "type": "integer", "minimum": 0 },
        "max_estimated_received_power_w": { "type": "number", "minimum": 0.0 },
        "min_estimated_received_power_w": { "type": "number", "minimum": 0.0 },
        "model_scope": { "const": "ideal_forward_line_command_path" }
      }
    },
    "samples": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/pathSample" } },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "vec3": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "type": "number" } },
    "vec2": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" } },
    "pathSample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sample_index", "command_angle_rad", "command_angle_deg", "scenario_config_hash", "final_direction", "mirror_normal_world", "reflected_direction", "target_id", "target_hit", "target_miss_reason", "hit_center_m", "target_local_coordinates_m", "target_incidence_angle_rad", "estimated_power_on_target_w", "estimated_received_power_w", "link_loss_db", "receiver_fov_status", "receiver_distance_m", "overall_status", "target_footprint_status", "receiver_return_status", "sample_status", "warnings", "time_s", "line_position"],
      "properties": {
        "sample_index": { "type": "integer", "minimum": 0 },
        "command_angle_rad": { "type": "number" },
        "command_angle_deg": { "type": "number" },
        "scenario_config_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "final_direction": { "$ref": "#/$defs/vec3" },
        "mirror_normal_world": { "oneOf": [{ "$ref": "#/$defs/vec3" }, { "type": "null" }] },
        "reflected_direction": { "oneOf": [{ "$ref": "#/$defs/vec3" }, { "type": "null" }] },
        "target_id": { "type": ["string", "null"] },
        "target_hit": { "type": "boolean" },
        "target_miss_reason": { "type": ["string", "null"] },
        "hit_center_m": { "oneOf": [{ "$ref": "#/$defs/vec3" }, { "type": "null" }] },
        "target_local_coordinates_m": { "oneOf": [{ "$ref": "#/$defs/vec2" }, { "type": "null" }] },
        "target_incidence_angle_rad": { "type": ["number", "null"], "minimum": 0.0 },
        "estimated_power_on_target_w": { "type": "number", "minimum": 0.0 },
        "estimated_received_power_w": { "type": "number", "minimum": 0.0 },
        "link_loss_db": { "type": ["number", "null"], "minimum": 0.0 },
        "receiver_fov_status": { "type": ["string", "null"] },
        "receiver_distance_m": { "type": ["number", "null"], "minimum": 0.0 },
        "overall_status": { "enum": ["pass", "warning", "fail"] },
        "target_footprint_status": { "enum": ["pass", "warning", "fail"] },
        "receiver_return_status": { "enum": ["pass", "warning", "fail"] },
        "sample_status": { "enum": ["target_miss", "outside_receiver_fov", "positive_return", "zero_return"] },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "time_s": { "type": "number", "minimum": 0.0 },
        "line_position": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    }
  }
}
