{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optic-ray.local/schemas/phase1_beam_summary.schema.json",
  "title": "Optic Ray Phase 1 Beam Summary",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_type", "manifest", "summary", "accuracy", "limitations"],
  "properties": {
    "schema_version": { "const": 1 },
    "report_type": { "const": "phase1_beam_summary" },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "scenario_id", "config_hash", "created_at_utc"],
      "properties": {
        "project_id": { "$ref": "common.schema.json#/$defs/identifier" },
        "scenario_id": { "$ref": "common.schema.json#/$defs/identifier" },
        "config_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "created_at_utc": { "type": "string", "format": "date-time" }
      }
    },
    "summary": { "type": "object", "additionalProperties": true },
    "accuracy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_purpose", "hardware_readiness", "confidence_level", "calibration_status", "warnings"],
      "properties": {
        "model_purpose": { "type": "string" },
        "hardware_readiness": { "type": "string" },
        "confidence_level": { "type": "string" },
        "calibration_status": { "type": "string" },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "limitations": { "type": "array", "items": { "type": "string" } }
  }
}
