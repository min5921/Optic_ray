{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optic-ray.local/schemas/phase2_optical_train_report.schema.json",
  "title": "Optic Ray Phase 2 Optical Train Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_type", "manifest", "summary", "accuracy", "model", "optical_train", "target_footprints", "receiver_return", "analytical_checks"],
  "properties": {
    "schema_version": { "const": 1 },
    "report_type": { "const": "phase2_optical_train" },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "scenario_id", "config_hash", "created_at_utc", "software_version", "backend", "real_dtype"],
      "properties": {
        "project_id": { "$ref": "common.schema.json#/$defs/identifier" },
        "scenario_id": { "$ref": "common.schema.json#/$defs/identifier" },
        "config_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "created_at_utc": { "type": "string", "format": "date-time" },
        "software_version": { "type": "string" },
        "backend": { "const": "numpy" },
        "real_dtype": { "const": "float64" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["overall_status", "optical_path_id", "final_plane", "final_radius_x_m", "final_radius_y_m", "final_power_w", "total_transmission", "total_loss_w", "total_loss_db", "processed_component_count", "unsupported_element_count", "target_hit_count", "estimated_power_on_target_w", "estimated_received_power_w", "link_loss_db", "q_parameter_status", "energy_ledger_status", "aperture_status", "target_footprint_status", "receiver_return_status"],
      "properties": {
        "overall_status": { "enum": ["pass", "warning", "fail"] },
        "optical_path_id": { "type": "string" },
        "final_plane": { "type": "string" },
        "final_radius_x_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "final_radius_y_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "final_power_w": { "type": "number", "exclusiveMinimum": 0.0 },
        "total_transmission": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "total_loss_w": { "type": "number", "minimum": 0.0 },
        "total_loss_db": { "type": ["number", "null"], "minimum": 0.0 },
        "processed_component_count": { "type": "integer", "minimum": 0 },
        "unsupported_element_count": { "type": "integer", "minimum": 0 },
        "target_hit_count": { "type": "integer", "minimum": 0 },
        "estimated_power_on_target_w": { "type": "number", "minimum": 0.0 },
        "estimated_received_power_w": { "type": "number", "minimum": 0.0 },
        "link_loss_db": { "type": ["number", "null"], "minimum": 0.0 },
        "q_parameter_status": { "enum": ["pass", "fail"] },
        "energy_ledger_status": { "enum": ["pass", "fail"] },
        "aperture_status": { "enum": ["pass", "fail"] },
        "target_footprint_status": { "enum": ["pass", "warning", "fail"] },
        "receiver_return_status": { "enum": ["pass", "warning", "fail"] }
      }
    },
    "accuracy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_purpose", "accuracy_mode", "hardware_readiness", "confidence_level", "calibration_status", "scope", "assumptions", "warnings"],
      "properties": {
        "model_purpose": { "enum": ["analytical_regression", "bench_template", "calibrated_hardware"] },
        "accuracy_mode": { "enum": ["relative_design", "absolute_radiometric", "coherent_fmcw"] },
        "hardware_readiness": { "enum": ["analytical_only", "bench_template", "calibrated"] },
        "confidence_level": { "enum": ["comparative", "engineering_estimate", "calibrated"] },
        "calibration_status": { "enum": ["uncalibrated", "calibrated"] },
        "scope": { "const": "source_to_static_mirror_rectangle_target_lambertian_virtual_aperture" },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["propagation_model", "radius_definition", "validity", "limitations"],
      "properties": {
        "propagation_model": { "const": "gaussian_q_abcd_plus_analytical_radiometry" },
        "radius_definition": { "const": "1/e^2 irradiance radius" },
        "validity": { "type": "string" },
        "limitations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "optical_train": {
      "type": "object",
      "additionalProperties": false,
      "required": ["optical_path_id", "element_sequence", "states", "power_ledger", "component_reports", "unsupported_elements", "warnings"],
      "properties": {
        "optical_path_id": { "type": "string" },
        "element_sequence": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "states": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "element_id", "component_ref", "port_id", "plane_role", "distance_along_path_m", "beam_state"],
            "properties": {
              "label": { "type": "string" },
              "element_id": { "type": "string" },
              "component_ref": { "type": "string" },
              "port_id": { "type": ["string", "null"] },
              "plane_role": { "type": "string" },
              "distance_along_path_m": { "type": "number", "minimum": 0.0 },
              "beam_state": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "power_ledger": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["optical_path_id", "element_id", "component_ref", "mechanism", "input_power_w", "output_power_w", "loss_w", "loss_db", "transmission_fraction", "model_source", "warning"],
            "properties": {
              "optical_path_id": { "type": "string" },
              "element_id": { "type": "string" },
              "component_ref": { "type": "string" },
              "mechanism": { "type": "string" },
              "input_power_w": { "type": "number", "exclusiveMinimum": 0.0 },
              "output_power_w": { "type": "number", "exclusiveMinimum": 0.0 },
              "loss_w": { "type": "number", "minimum": 0.0 },
              "loss_db": { "type": ["number", "null"], "minimum": 0.0 },
              "transmission_fraction": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
              "model_source": { "type": "string" },
              "warning": { "type": ["string", "null"] }
            }
          }
        },
        "component_reports": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "unsupported_elements": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "target_footprints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["target_id", "material_ref", "hit", "estimated_power_on_target_w", "assumptions", "warnings"],
        "properties": {
          "target_id": { "type": "string" },
          "material_ref": { "type": "string" },
          "hit": { "type": "boolean" },
          "estimated_power_on_target_w": { "type": "number", "minimum": 0.0 },
          "assumptions": { "type": "array", "items": { "type": "string" } },
          "warnings": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "receiver_return": {
      "type": "object",
      "additionalProperties": true,
      "required": ["model", "returns", "total_estimated_received_power_w", "total_estimated_power_on_target_w", "total_link_loss_db", "assumptions"],
      "properties": {
        "model": { "const": "lambertian_small_footprint_receiver_aperture" },
        "returns": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["target_id", "material_ref", "material_model", "receiver_fov_status", "estimated_power_on_target_w", "estimated_received_power_w", "status", "assumptions", "warnings"],
            "properties": {
              "target_id": { "type": "string" },
              "material_ref": { "type": "string" },
              "material_model": { "type": "string" },
              "receiver_fov_status": { "type": "string" },
              "estimated_power_on_target_w": { "type": "number", "minimum": 0.0 },
              "estimated_received_power_w": { "type": "number", "minimum": 0.0 },
              "status": { "type": "string" },
              "assumptions": { "type": "array", "items": { "type": "string" } },
              "warnings": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "total_estimated_received_power_w": { "type": "number", "minimum": 0.0 },
        "total_estimated_power_on_target_w": { "type": "number", "minimum": 0.0 },
        "total_link_loss_db": { "type": ["number", "null"], "minimum": 0.0 },
        "assumptions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "analytical_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_scope", "q_parameter", "energy_ledger", "aperture_fraction", "target_footprint", "receiver_return", "external_validation_status"],
      "properties": {
        "check_scope": { "const": "internal_consistency_only" },
        "q_parameter": { "$ref": "#/$defs/statusCheck" },
        "energy_ledger": { "$ref": "#/$defs/statusCheck" },
        "aperture_fraction": { "$ref": "#/$defs/statusCheck" },
        "target_footprint": { "$ref": "#/$defs/statusCheck" },
        "receiver_return": { "$ref": "#/$defs/statusCheck" },
        "external_validation_status": { "const": "not_evaluated" }
      }
    }
  },
  "$defs": {
    "statusCheck": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "message"],
      "properties": {
        "status": { "enum": ["pass", "warning", "fail"] },
        "message": { "type": "string" }
      }
    }
  }
}
