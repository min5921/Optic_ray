{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optic-ray.local/schemas/phase2_optical_train_report.schema.json",
  "title": "Optic Ray Phase 2 Optical Train Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_type",
    "manifest",
    "summary",
    "accuracy",
    "model",
    "optical_train",
    "target_footprints",
    "scene_energy_ledger",
    "receiver_return",
    "analytical_checks"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "report_type": { "const": "phase2_optical_train" },
    "manifest": { "$ref": "#/$defs/manifest" },
    "summary": { "$ref": "#/$defs/summary" },
    "accuracy": { "$ref": "#/$defs/accuracy" },
    "model": { "$ref": "#/$defs/model" },
    "optical_train": { "$ref": "#/$defs/opticalTrain" },
    "target_footprints": {
      "type": "array",
      "items": { "$ref": "#/$defs/targetFootprint" }
    },
    "scene_energy_ledger": { "$ref": "#/$defs/sceneEnergyLedger" },
    "receiver_return": { "$ref": "#/$defs/receiverReturnSection" },
    "analytical_checks": { "$ref": "#/$defs/analyticalChecks" }
  },
  "$defs": {
    "vec3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "number" }
    },
    "nullableNumber": {
      "type": ["number", "null"]
    },
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "scenario_id",
        "config_hash",
        "created_at_utc",
        "software_version",
        "backend",
        "real_dtype"
      ],
      "properties": {
        "project_id": { "$ref": "common.schema.json#/$defs/identifier" },
        "scenario_id": { "$ref": "common.schema.json#/$defs/identifier" },
        "config_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "created_at_utc": { "type": "string", "format": "date-time" },
        "software_version": { "type": "string" },
        "backend": { "const": "numpy" },
        "real_dtype": { "const": "float64" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall_status",
        "optical_train_status",
        "optical_path_id",
        "final_plane",
        "final_radius_x_m",
        "final_radius_y_m",
        "final_power_w",
        "total_transmission",
        "total_loss_w",
        "total_loss_db",
        "processed_component_count",
        "unsupported_element_count",
        "target_hit_count",
        "estimated_power_on_target_w",
        "estimated_received_power_w",
        "link_loss_db",
        "q_parameter_status",
        "energy_ledger_status",
        "aperture_status",
        "target_footprint_status",
        "receiver_return_status"
      ],
      "properties": {
        "overall_status": { "enum": ["pass", "warning", "fail"] },
        "optical_train_status": { "enum": ["completed", "terminated"] },
        "optical_path_id": { "type": "string" },
        "final_plane": { "type": "string" },
        "final_radius_x_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "final_radius_y_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "final_power_w": { "type": "number", "minimum": 0.0 },
        "total_transmission": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "total_loss_w": { "type": "number", "minimum": 0.0 },
        "total_loss_db": { "type": ["number", "null"], "minimum": 0.0 },
        "processed_component_count": { "type": "integer", "minimum": 0 },
        "unsupported_element_count": { "type": "integer", "minimum": 0 },
        "target_hit_count": { "type": "integer", "minimum": 0 },
        "estimated_power_on_target_w": { "type": "number", "minimum": 0.0 },
        "estimated_received_power_w": { "type": "number", "minimum": 0.0 },
        "link_loss_db": { "type": ["number", "null"], "minimum": 0.0 },
        "q_parameter_status": { "enum": ["pass", "fail"] },
        "energy_ledger_status": { "enum": ["pass", "fail"] },
        "aperture_status": { "enum": ["pass", "fail"] },
        "target_footprint_status": { "enum": ["pass", "warning", "fail"] },
        "receiver_return_status": { "enum": ["pass", "warning", "fail"] }
      }
    },
    "accuracy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_purpose",
        "accuracy_mode",
        "hardware_readiness",
        "confidence_level",
        "calibration_status",
        "calibration_evidence",
        "scope",
        "assumptions",
        "warnings"
      ],
      "properties": {
        "model_purpose": {
          "enum": ["analytical_regression", "bench_template", "calibrated_hardware"]
        },
        "accuracy_mode": {
          "enum": ["relative_design", "absolute_radiometric", "coherent_fmcw"]
        },
        "hardware_readiness": {
          "enum": ["analytical_only", "bench_template", "calibrated"]
        },
        "confidence_level": {
          "enum": ["comparative", "engineering_estimate", "calibrated"]
        },
        "calibration_status": { "enum": ["uncalibrated", "calibrated"] },
        "calibration_evidence": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "scenario.schema.json#/properties/calibration_evidence" }
          ]
        },
        "scope": {
          "const": "source_to_static_mirror_rectangle_target_lambertian_virtual_aperture"
        },
        "assumptions": { "$ref": "#/$defs/stringArray" },
        "warnings": { "$ref": "#/$defs/stringArray" }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "propagation_model",
        "radius_definition",
        "validity",
        "limitations"
      ],
      "properties": {
        "propagation_model": {
          "const": "gaussian_q_abcd_plus_analytical_radiometry"
        },
        "radius_definition": { "const": "1/e^2 irradiance radius" },
        "validity": { "type": "string" },
        "limitations": { "$ref": "#/$defs/stringArray" }
      }
    },
    "beamState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "time_s",
        "origin_m",
        "direction",
        "transverse_x_axis",
        "transverse_y_axis",
        "wavelength_m",
        "power_w",
        "profile_kind",
        "propagation_model",
        "waist_radius_x_m",
        "waist_radius_y_m",
        "m2_x",
        "m2_y",
        "rayleigh_range_x_m",
        "rayleigh_range_y_m",
        "divergence_x_rad",
        "divergence_y_rad",
        "distance_from_waist_m",
        "radius_x_m",
        "radius_y_m",
        "polarization",
        "optical_path_length_m",
        "accumulated_transmission",
        "source_component_id",
        "source_component_ref",
        "optical_path_id"
      ],
      "properties": {
        "time_s": { "type": "number" },
        "origin_m": { "$ref": "#/$defs/vec3" },
        "direction": { "$ref": "#/$defs/vec3" },
        "transverse_x_axis": { "$ref": "#/$defs/vec3" },
        "transverse_y_axis": { "$ref": "#/$defs/vec3" },
        "wavelength_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "power_w": { "type": "number", "minimum": 0.0 },
        "profile_kind": {
          "enum": ["circular_gaussian", "elliptical_gaussian", "line_gaussian"]
        },
        "propagation_model": { "const": "gaussian_m2" },
        "waist_radius_x_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "waist_radius_y_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "m2_x": { "type": "number", "minimum": 1.0 },
        "m2_y": { "type": "number", "minimum": 1.0 },
        "rayleigh_range_x_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "rayleigh_range_y_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "divergence_x_rad": { "type": "number", "exclusiveMinimum": 0.0 },
        "divergence_y_rad": { "type": "number", "exclusiveMinimum": 0.0 },
        "distance_from_waist_m": { "type": "number" },
        "radius_x_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "radius_y_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "polarization": { "type": "string" },
        "optical_path_length_m": { "type": "number", "minimum": 0.0 },
        "accumulated_transmission": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "source_component_id": { "type": ["string", "null"] },
        "source_component_ref": { "type": ["string", "null"] },
        "optical_path_id": { "type": ["string", "null"] }
      }
    },
    "beamPlane": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "element_id",
        "component_ref",
        "port_id",
        "plane_role",
        "distance_along_path_m",
        "beam_state"
      ],
      "properties": {
        "label": { "type": "string" },
        "element_id": { "type": "string" },
        "component_ref": { "type": "string" },
        "port_id": { "type": ["string", "null"] },
        "plane_role": { "type": "string" },
        "distance_along_path_m": { "type": "number", "minimum": 0.0 },
        "beam_state": { "$ref": "#/$defs/beamState" }
      }
    },
    "powerLedgerEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "optical_path_id",
        "element_id",
        "component_ref",
        "mechanism",
        "input_power_w",
        "output_power_w",
        "loss_w",
        "loss_db",
        "transmission_fraction",
        "model_source",
        "warning"
      ],
      "properties": {
        "optical_path_id": { "type": "string" },
        "element_id": { "type": "string" },
        "component_ref": { "type": "string" },
        "mechanism": {
          "enum": [
            "free_space_propagation",
            "circular_aperture_clipping",
            "component_power_transmission",
            "mirror_rectangular_aperture",
            "mirror_reflectivity",
            "component_geometric_miss"
          ]
        },
        "input_power_w": { "type": "number", "minimum": 0.0 },
        "output_power_w": { "type": "number", "minimum": 0.0 },
        "loss_w": { "type": "number", "minimum": 0.0 },
        "loss_db": { "type": ["number", "null"], "minimum": 0.0 },
        "transmission_fraction": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "model_source": { "type": "string" },
        "warning": { "type": ["string", "null"] }
      }
    },
    "circularApertureClip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aperture_radius_m",
        "beam_radius_x_m",
        "beam_radius_y_m",
        "beam_center_u_m",
        "beam_center_v_m",
        "incidence_cosine",
        "transmission_fraction",
        "clipped_fraction",
        "input_power_w",
        "output_power_w",
        "loss_w",
        "loss_db",
        "quadrature_order",
        "method"
      ],
      "properties": {
        "aperture_radius_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "beam_radius_x_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "beam_radius_y_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "beam_center_u_m": { "type": "number" },
        "beam_center_v_m": { "type": "number" },
        "incidence_cosine": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "transmission_fraction": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "clipped_fraction": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "input_power_w": { "type": "number", "minimum": 0.0 },
        "output_power_w": { "type": "number", "minimum": 0.0 },
        "loss_w": { "type": "number", "minimum": 0.0 },
        "loss_db": { "type": ["number", "null"], "minimum": 0.0 },
        "quadrature_order": {
          "type": ["integer", "null"],
          "minimum": 16
        },
        "method": { "type": "string" }
      }
    },
    "mirrorApertureClip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clear_width_m",
        "clear_height_m",
        "beam_center_u_m",
        "beam_center_v_m",
        "incidence_cosine",
        "incidence_angle_rad",
        "incidence_angle_convention",
        "transmission_fraction",
        "clipped_fraction",
        "input_power_w",
        "output_power_w",
        "loss_w",
        "loss_db",
        "status",
        "quadrature_order",
        "method"
      ],
      "properties": {
        "clear_width_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "clear_height_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "beam_center_u_m": { "type": "number" },
        "beam_center_v_m": { "type": "number" },
        "incidence_cosine": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "incidence_angle_rad": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.5707963267948966
        },
        "incidence_angle_convention": {
          "const": "angle_from_surface_normal_radians"
        },
        "transmission_fraction": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "clipped_fraction": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "input_power_w": { "type": "number", "minimum": 0.0 },
        "output_power_w": { "type": "number", "minimum": 0.0 },
        "loss_w": { "type": "number", "minimum": 0.0 },
        "loss_db": { "type": ["number", "null"], "minimum": 0.0 },
        "status": { "enum": ["pass", "warning", "fail"] },
        "quadrature_order": { "type": "integer", "minimum": 16 },
        "method": { "type": "string" }
      }
    },
    "collimatorReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "element_id",
        "component_ref",
        "component_type",
        "model",
        "model_level",
        "ray_model",
        "abcd_matrix",
        "effective_focal_length_m",
        "clear_aperture_diameter_m",
        "aperture_center_world_m",
        "interaction_point_world_m",
        "beam_center_u_m",
        "beam_center_v_m",
        "incident_direction",
        "output_chief_ray_direction",
        "aperture_clip",
        "power_transmission",
        "input_beam_state",
        "output_beam_state",
        "assumptions"
      ],
      "properties": {
        "element_id": { "type": "string" },
        "component_ref": { "type": "string" },
        "component_type": { "const": "collimator" },
        "model": { "const": "ideal_thin_lens" },
        "model_level": { "type": "string" },
        "ray_model": { "const": "paraxial_thin_lens_chief_ray" },
        "abcd_matrix": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": { "type": "number" }
          }
        },
        "effective_focal_length_m": {
          "type": "number",
          "exclusiveMinimum": 0.0
        },
        "clear_aperture_diameter_m": {
          "type": "number",
          "exclusiveMinimum": 0.0
        },
        "aperture_center_world_m": { "$ref": "#/$defs/vec3" },
        "interaction_point_world_m": { "$ref": "#/$defs/vec3" },
        "beam_center_u_m": { "type": "number" },
        "beam_center_v_m": { "type": "number" },
        "incident_direction": { "$ref": "#/$defs/vec3" },
        "output_chief_ray_direction": { "$ref": "#/$defs/vec3" },
        "aperture_clip": { "$ref": "#/$defs/circularApertureClip" },
        "power_transmission": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "input_beam_state": { "$ref": "#/$defs/beamState" },
        "output_beam_state": { "$ref": "#/$defs/beamState" },
        "assumptions": { "$ref": "#/$defs/stringArray" }
      }
    },
    "mirrorReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "element_id",
        "component_ref",
        "component_type",
        "model",
        "surface_model",
        "model_level",
        "incident_direction",
        "scanner_pose_model",
        "scanner_command_angle_rad",
        "scanner_rotation_axis_input_world",
        "scanner_rotation_axis_world",
        "scanner_pivot_world_m",
        "surface_origin_world_m",
        "interaction_point_world_m",
        "beam_center_u_m",
        "beam_center_v_m",
        "surface_normal_world",
        "aperture_x_axis_world",
        "aperture_y_axis_world",
        "reflected_direction",
        "reflected_direction_world",
        "incidence_angle_rad",
        "incidence_angle_convention",
        "clear_width_m",
        "clear_height_m",
        "aperture_status",
        "aperture_transmission_fraction",
        "aperture_clip",
        "power_reflectivity",
        "input_beam_state",
        "output_beam_state",
        "assumptions",
        "warnings"
      ],
      "properties": {
        "element_id": { "type": "string" },
        "component_ref": { "type": "string" },
        "component_type": { "const": "scanner_mirror" },
        "model": { "const": "flat_mirror" },
        "surface_model": { "const": "flat_mirror" },
        "model_level": { "type": "string" },
        "incident_direction": { "$ref": "#/$defs/vec3" },
        "scanner_pose_model": { "const": "static_command_angle" },
        "scanner_command_angle_rad": { "type": "number" },
        "scanner_rotation_axis_input_world": { "$ref": "#/$defs/vec3" },
        "scanner_rotation_axis_world": { "$ref": "#/$defs/vec3" },
        "scanner_pivot_world_m": { "$ref": "#/$defs/vec3" },
        "surface_origin_world_m": { "$ref": "#/$defs/vec3" },
        "interaction_point_world_m": { "$ref": "#/$defs/vec3" },
        "beam_center_u_m": { "type": "number" },
        "beam_center_v_m": { "type": "number" },
        "surface_normal_world": { "$ref": "#/$defs/vec3" },
        "aperture_x_axis_world": { "$ref": "#/$defs/vec3" },
        "aperture_y_axis_world": { "$ref": "#/$defs/vec3" },
        "reflected_direction": { "$ref": "#/$defs/vec3" },
        "reflected_direction_world": { "$ref": "#/$defs/vec3" },
        "incidence_angle_rad": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.5707963267948966
        },
        "incidence_angle_convention": {
          "const": "angle_from_surface_normal_radians"
        },
        "clear_width_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "clear_height_m": { "type": "number", "exclusiveMinimum": 0.0 },
        "aperture_status": { "enum": ["pass", "warning", "fail"] },
        "aperture_transmission_fraction": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "aperture_clip": { "$ref": "#/$defs/mirrorApertureClip" },
        "power_reflectivity": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "input_beam_state": { "$ref": "#/$defs/beamState" },
        "output_beam_state": { "$ref": "#/$defs/beamState" },
        "assumptions": { "$ref": "#/$defs/stringArray" },
        "warnings": { "$ref": "#/$defs/stringArray" }
      }
    },
    "unsupportedElement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["element_id", "component_ref", "component_type", "reason"],
      "properties": {
        "element_id": { "type": "string" },
        "component_ref": { "type": "string" },
        "component_type": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "termination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "element_id",
        "component_ref",
        "component_type",
        "reason",
        "last_beam_origin_m",
        "plane_origin_world_m",
        "plane_normal_world",
        "beam_center_u_m",
        "beam_center_v_m",
        "intersection",
        "warning"
      ],
      "properties": {
        "element_id": { "type": "string" },
        "component_ref": { "type": "string" },
        "component_type": { "type": "string" },
        "reason": { "type": "string" },
        "last_beam_origin_m": { "$ref": "#/$defs/vec3" },
        "plane_origin_world_m": { "$ref": "#/$defs/vec3" },
        "plane_normal_world": { "$ref": "#/$defs/vec3" },
        "beam_center_u_m": { "type": ["number", "null"] },
        "beam_center_v_m": { "type": ["number", "null"] },
        "intersection": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "hit",
                "miss_reason",
                "distance_m",
                "point_m",
                "ray_direction",
                "plane_origin_m",
                "plane_normal",
                "denominator",
                "epsilon"
              ],
              "properties": {
                "hit": { "type": "boolean" },
                "miss_reason": { "type": ["string", "null"] },
                "distance_m": { "type": ["number", "null"], "minimum": 0.0 },
                "point_m": {
                  "oneOf": [
                    { "type": "null" },
                    { "$ref": "#/$defs/vec3" }
                  ]
                },
                "ray_direction": { "$ref": "#/$defs/vec3" },
                "plane_origin_m": { "$ref": "#/$defs/vec3" },
                "plane_normal": { "$ref": "#/$defs/vec3" },
                "denominator": { "type": "number" },
                "epsilon": { "type": "number", "exclusiveMinimum": 0.0 }
              }
            }
          ]
        },
        "warning": { "type": "string" }
      }
    },
    "opticalTrain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "optical_path_id",
        "element_sequence",
        "states",
        "power_ledger",
        "component_reports",
        "unsupported_elements",
        "terminated",
        "termination",
        "warnings"
      ],
      "properties": {
        "optical_path_id": { "type": "string" },
        "element_sequence": {
          "type": "array",
          "minItems": 1,
