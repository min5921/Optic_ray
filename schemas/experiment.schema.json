{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://optic-ray.local/schemas/experiment.schema.json",
  "title": "Optic Ray Experiment",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "experiment_id", "base_config", "design", "sweeps", "metrics", "comparison", "execution"],
  "properties": {
    "schema_version": { "const": 1 },
    "experiment_id": { "$ref": "common.schema.json#/$defs/identifier" },
    "base_config": { "type": "string", "minLength": 1 },
    "design": { "enum": ["one_factor_at_a_time", "cartesian_grid", "named_variants", "monte_carlo", "calibration_fit"] },
    "sweeps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["parameter", "values"],
        "properties": {
          "parameter": { "type": "string", "minLength": 1 },
          "values": { "type": "array", "minItems": 1 }
        }
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseline_run", "component_swap_placement_policy"],
      "properties": {
        "baseline_run": { "type": "string" },
        "component_swap_placement_policy": { "enum": ["preserve_existing_assembly", "reconnect_ports", "reoptimize_selected_parameters"] },
        "report_absolute_delta": { "type": "boolean" },
        "report_relative_delta": { "type": "boolean" }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["random_seed_policy", "backend", "max_runs_without_confirmation"],
      "properties": {
        "random_seed_policy": { "enum": ["fixed", "per_run", "explicit"] },
        "backend": { "enum": ["numpy", "cupy"] },
        "max_runs_without_confirmation": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
